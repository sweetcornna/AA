{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "AA Ledger",
  "mainBinaryName": "aa-ledger",
  "version": "0.0.1",
  "identifier": "com.aa.expense",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "AA 记账",
        "width": 420,
        "height": 820,
        "minWidth": 360,
        "minHeight": 600,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": ["aa"]
      }
    }
  }
}
