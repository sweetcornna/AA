# Copy to apps/app/.env and fill in from `supabase start` output (local) or
# your Supabase project settings (cloud).
VITE_SUPABASE_URL=http://127.0.0.1:54321
VITE_SUPABASE_ANON_KEY=your-local-anon-key

# Base URL used to build invite links (defaults to window.location.origin).
# VITE_APP_BASE_URL=https://aa.example.com
